rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsUserDocument(userId);

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /privateAiUsage/{userId} {
      allow read, write: if false;
    }

    match /privateEntitlements/{userId} {
      allow read, write: if false;
    }

    match /privateProductEvents/{eventId} {
      allow read, write: if false;
    }

    match /privateProductEventRate/{userId} {
      allow read, write: if false;
    }

    match /privateInstallationTrials/{installationHash} {
      allow read, write: if false;
    }

    match /privateAnonymousMigrations/{anonymousUid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
